<!DOCTYPE html>
<html>
<head>
    <title>Kids Area Welcome</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <style>
        /* This removes all borders and centers the image perfectly */
        html, body {
            height: 100%;
            width: 100%;
            margin: 0;
            padding: 0;
            background-color: #e6f0eb; /* A soft background color that matches the sign */
            display: flex;
            justify-content: center;
            align-items: center;
            overflow: hidden; 
        }

        img {
            max-width: 100%;
            max-height: 100vh;
            object-fit: contain; /* Ensures the whole sign fits without stretching */
            box-shadow: 0px 4px 15px rgba(0,0,0,0.2); /* Adds a subtle shadow so it looks like a real poster */
        }
    </style>
</head>
<body>

    <img src="sign.jpg" alt="Welcome to the Kids & Students Area">

</body>
</html>
